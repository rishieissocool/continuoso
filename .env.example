OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/continuoso
OPENROUTER_TITLE=continuoso

# Local Ollama (optional). Routing defaults to OpenRouter (`free` tier); set OLLAMA_ENABLED=1 and
# override task_class_defaults to `local` in config/routing.yaml or .continuoso/routing.yaml to use it.
#   ollama pull qwen2.5:7b
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=180

# Optional: Claude Code CLI (heavy tier). Auto-detects `claude` on PATH and
# Windows npm shims (%APPDATA%\npm\claude.cmd). If detection fails, set the full path:
#   CLAUDE_CODE_BIN=C:\Users\YOU\AppData\Roaming\npm\claude.cmd
CLAUDE_CODE_BIN=

# Optional: where the target app lives. Defaults to ./workspace
CONTINUOSO_WORKSPACE=./workspace

# Optional: session theme for this run when stdin is not a TTY or you use --no-session-prompt.
# CLI also accepts: continuoso run --focus "make the frontend better"
# CONTINUOSO_SESSION_FOCUS=improve responsive layout and accessibility

# Optional: logging level
CONTINUOSO_LOG_LEVEL=INFO

# Log full raw model replies at INFO (reasoning blocks, JSON) — main "see what it's thinking" switch
CONTINUOSO_VERBOSE_LLM=1
# CONTINUOSO_VERBOSE_LLM_CHARS=8000

# Loop tuning: snapshot runs pytest each iteration by default (feeds failures to the planner).
# Set CONTINUOSO_SNAPSHOT_TESTS=0 to skip (faster if you have huge suites or no tests).
# CONTINUOSO_SNAPSHOT_TESTS=1
# CONTINUOSO_PYTEST_TIMEOUT=300
# CONTINUOSO_ITERATION_DELAY_SEC=5
# CONTINUOSO_SNAPSHOT_MAX_FILES=500
# Set to 0 for unlimited snapshot file walk (not recommended on large trees).
