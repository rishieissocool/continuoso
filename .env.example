OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/continuoso
OPENROUTER_TITLE=continuoso

# Local Ollama (default tier). OpenAI-compatible API; pull model first, e.g.:
#   ollama pull qwen2.5:7b
# Use qwen3:8b or another tag with OLLAMA_MODEL=qwen3:8b
OLLAMA_ENABLED=1
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=180

# Optional: Claude Code CLI (heavy tier). Auto-detects `claude` on PATH and
# Windows npm shims (%APPDATA%\npm\claude.cmd). If detection fails, set the full path:
#   CLAUDE_CODE_BIN=C:\Users\YOU\AppData\Roaming\npm\claude.cmd
CLAUDE_CODE_BIN=

# Optional: where the target app lives. Defaults to ./workspace
CONTINUOSO_WORKSPACE=./workspace

# Optional: logging level (use DEBUG for full LLM raw output previews in logs)
CONTINUOSO_LOG_LEVEL=DEBUG

# Snapshot step runs pytest on the project (can look "stuck" for minutes). Disable for speed:
# CONTINUOSO_SNAPSHOT_TESTS=0
# CONTINUOSO_PYTEST_TIMEOUT=120
